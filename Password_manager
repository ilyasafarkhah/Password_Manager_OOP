class PasswordEntry:
    def init(self, username, site, password):
        self.username = username
        self.site = site
        self.password = password

    @property
    def password(self):
        return self.__password

    @password.setter
    def password(self, password):
        if len(password) < 8:
            raise ValueError("Password must be at least 8 characters")
        else:
            self.__password = password

    def str(self):
        return f"Username: {self.username}, Site: {self.site}, Password: {self.password}"


class PasswordManager:

    def init(self):
        self.__passwordlist = []

    def add_password(self, username, site, password):
        for entry in self.__passwordlist:
            if entry.site == site and entry.username == username:
                entry.password = password  
                return
        new_entry = PasswordEntry(username, site, password)
        self.__passwordlist.append(new_entry)

    def show(self):
        for entry in self.__passwordlist:
            print(entry)

    def delete(self, username):
        for entry in self.__passwordlist:
            if entry.username == username:
                self.__passwordlist.remove(entry)
                return True
        print("username not found")
        return False

    def search(self, username):
        for entry in self.__passwordlist:
            if entry.username == username:  
                return entry
        print("username not found")
        return None